# Application
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=change-me-in-production
# Session TTL in days. Set to 0 for no expiry.
SESSION_TTL_DAYS=30

# Database
# Use 'localhost' when running locally, 'postgres' when running inside Docker
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=citizenonpetrol
DB_PASSWORD=citizen123
DB_NAME=cop_db
DB_TIMEZONE=UTC

# Email Service (optional - for OTP sending)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# SMS Service (optional - for OTP sending)
# SMS_API_KEY=your-sms-api-key
# SMS_API_URL=https://api.sms-provider.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=